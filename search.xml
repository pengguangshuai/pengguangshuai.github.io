    <title>预测结果对比(论文绘图)</title>
    <url>/2022/04/26/huizhi/</url>
    <content><![CDATA[<p>实验结果精细化绘图展示</p>
<span id="more"></span>
<figure class="highlight python"><table><tr><td class="code"><pre><span class="line">clc,clear;</span><br><span class="line">data_2009=readmatrix(<span class="string">&#x27;C:\Users\Jone\Desktop\2009预测值和真实值.csv&#x27;</span>);</span><br><span class="line">data_2010=readmatrix(<span class="string">&#x27;C:\Users\Jone\Desktop\2010预测值和真实值.csv&#x27;</span>);</span><br><span class="line">data_2009=data_2009(<span class="number">2</span>:<span class="number">366</span>,:);</span><br><span class="line"></span><br><span class="line">month_day=[<span class="number">31</span> <span class="number">28</span> <span class="number">31</span> <span class="number">30</span> <span class="number">31</span> <span class="number">30</span> <span class="number">31</span> <span class="number">31</span> <span class="number">30</span> <span class="number">31</span> <span class="number">30</span> <span class="number">31</span>];</span><br><span class="line">month_start_day=cumsum(month_day);</span><br><span class="line">month_start_day=[<span class="number">0</span> month_start_day(<span class="number">1</span>:end-<span class="number">1</span>)];%设定标记xtick的位置</span><br><span class="line"></span><br><span class="line">figure(<span class="string">&#x27;position&#x27;</span>,[<span class="number">100</span>,<span class="number">100</span>,<span class="number">1000</span>,<span class="number">400</span>])</span><br><span class="line">ha=tight_subplot(<span class="number">2</span>,<span class="number">1</span>,[<span class="number">.1</span> <span class="number">.1</span>],[<span class="number">.15</span> <span class="number">.1</span>],[<span class="number">.12</span> <span class="number">.08</span>]);%设置上下边界距离</span><br><span class="line">axes(ha(<span class="number">1</span>))</span><br><span class="line">plot(data_2009(:,<span class="number">1</span>),data_2009(:,<span class="number">3</span>),<span class="string">&#x27;color&#x27;</span>,<span class="string">&#x27;k&#x27;</span>,<span class="string">&#x27;linewidth&#x27;</span>,<span class="number">2</span>,<span class="string">&#x27;linestyle&#x27;</span>,<span class="string">&#x27;-&#x27;</span>)</span><br><span class="line">hold on</span><br><span class="line">plot(data_2009(:,<span class="number">1</span>),data_2009(:,<span class="number">2</span>),<span class="string">&#x27;color&#x27;</span>,[<span class="number">0</span>,<span class="number">128</span>/<span class="number">256</span>,<span class="number">0</span>],<span class="string">&#x27;linewidth&#x27;</span>,<span class="number">2</span>,<span class="string">&#x27;linestyle&#x27;</span>,<span class="string">&#x27;--&#x27;</span>)</span><br><span class="line">legend(&#123;<span class="string">&#x27;Observed&#x27;</span>,<span class="string">&#x27;EMD-LSTM&#x27;</span>&#125;)</span><br><span class="line">ylabel(&#123;<span class="string">&#x27;xxxx&#x27;</span>,<span class="string">&#x27;(cm^-^2d^-^1.sr^-^1)&#x27;</span>,<span class="string">&#x27; &#x27;</span>&#125;)</span><br><span class="line">xlim([<span class="number">0</span>,<span class="number">365</span>])</span><br><span class="line"><span class="built_in">set</span>(gca,<span class="string">&#x27;xtick&#x27;</span>,month_start_day,<span class="string">&#x27;xticklabel&#x27;</span>,&#123;<span class="string">&#x27;Jan&#x27;</span>,<span class="string">&#x27;Feb&#x27;</span>,<span class="string">&#x27;Mar&#x27;</span>,<span class="string">&#x27;Apr&#x27;</span>,<span class="string">&#x27;May&#x27;</span>,<span class="string">&#x27;June&#x27;</span>,<span class="string">&#x27;July&#x27;</span>,<span class="string">&#x27;Agu&#x27;</span>,<span class="string">&#x27;Sept&#x27;</span>,<span class="string">&#x27;Oct&#x27;</span>,<span class="string">&#x27;Nov&#x27;</span>,<span class="string">&#x27;Dec&#x27;</span>&#125;,<span class="string">&#x27;FontName&#x27;</span>,<span class="string">&#x27;Times New Roman&#x27;</span>,<span class="string">&#x27;FontWeight&#x27;</span>,<span class="string">&#x27;bold&#x27;</span>,<span class="string">&#x27;FontSize&#x27;</span>,<span class="number">10</span>)</span><br><span class="line">text(<span class="number">275.02</span>,<span class="number">8.154</span>,<span class="string">&#x27;Year 2009&#x27;</span>,<span class="string">&#x27;FontName&#x27;</span>,<span class="string">&#x27;Times New Roman&#x27;</span>,<span class="string">&#x27;FontWeight&#x27;</span>,<span class="string">&#x27;bold&#x27;</span>,<span class="string">&#x27;FontSize&#x27;</span>,<span class="number">12</span>)</span><br><span class="line">ylim([<span class="number">4</span>,<span class="number">9</span>])</span><br><span class="line"></span><br><span class="line"></span><br><span class="line">axes(ha(<span class="number">2</span>))</span><br><span class="line">plot(data_2009(:,<span class="number">1</span>),data_2010(:,<span class="number">12</span>),<span class="string">&#x27;color&#x27;</span>,<span class="string">&#x27;k&#x27;</span>,<span class="string">&#x27;linewidth&#x27;</span>,<span class="number">2</span>,<span class="string">&#x27;linestyle&#x27;</span>,<span class="string">&#x27;-&#x27;</span>)</span><br><span class="line">hold on</span><br><span class="line">plot(data_2009(:,<span class="number">1</span>),data_2010(:,<span class="number">10</span>),<span class="string">&#x27;color&#x27;</span>,[<span class="number">0</span>,<span class="number">128</span>/<span class="number">256</span>,<span class="number">0</span>],<span class="string">&#x27;linewidth&#x27;</span>,<span class="number">2</span>,<span class="string">&#x27;linestyle&#x27;</span>,<span class="string">&#x27;--&#x27;</span>)</span><br><span class="line">legend(&#123;<span class="string">&#x27;Observed&#x27;</span>,<span class="string">&#x27;EMD-LSTM&#x27;</span>&#125;)</span><br><span class="line">ylabel(&#123;<span class="string">&#x27;xxxxxxx&#x27;</span>,<span class="string">&#x27;(cm^-^2d^-^1.sr^-^1)&#x27;</span>,<span class="string">&#x27; &#x27;</span>&#125;,<span class="string">&#x27;position&#x27;</span>,[-<span class="number">7.2</span>,<span class="number">6.5</span>,-<span class="number">1</span>])</span><br><span class="line">xlim([<span class="number">0</span>,<span class="number">365</span>])</span><br><span class="line"><span class="built_in">set</span>(gca,<span class="string">&#x27;ytick&#x27;</span>,<span class="number">4</span>:<span class="number">10</span>,<span class="string">&#x27;xtick&#x27;</span>,month_start_day,<span class="string">&#x27;xticklabel&#x27;</span>,&#123;<span class="string">&#x27;Jan&#x27;</span>,<span class="string">&#x27;Feb&#x27;</span>,<span class="string">&#x27;Mar&#x27;</span>,<span class="string">&#x27;Apr&#x27;</span>,<span class="string">&#x27;May&#x27;</span>,<span class="string">&#x27;June&#x27;</span>,<span class="string">&#x27;July&#x27;</span>,<span class="string">&#x27;Agu&#x27;</span>,<span class="string">&#x27;Sept&#x27;</span>,<span class="string">&#x27;Oct&#x27;</span>,<span class="string">&#x27;Nov&#x27;</span>,<span class="string">&#x27;Dec&#x27;</span>&#125;,<span class="string">&#x27;FontName&#x27;</span>,<span class="string">&#x27;Times New Roman&#x27;</span>,<span class="string">&#x27;FontWeight&#x27;</span>,<span class="string">&#x27;bold&#x27;</span>,<span class="string">&#x27;FontSize&#x27;</span>,<span class="number">10</span>)</span><br><span class="line">text(<span class="number">275.02</span>,<span class="number">9</span>,<span class="string">&#x27;Year 2010&#x27;</span>,<span class="string">&#x27;FontName&#x27;</span>,<span class="string">&#x27;Times New Roman&#x27;</span>,<span class="string">&#x27;FontWeight&#x27;</span>,<span class="string">&#x27;bold&#x27;</span>,<span class="string">&#x27;FontSize&#x27;</span>,<span class="number">12</span>)</span><br><span class="line">ylim([<span class="number">4</span>,<span class="number">10</span>])</span><br><span class="line">xlabel(<span class="string">&#x27;Time (Month)&#x27;</span>,<span class="string">&#x27;position&#x27;</span>,[<span class="number">180.675</span>,<span class="number">2.677</span>,-<span class="number">1</span>])</span><br></pre></td></tr></table></figure>
<p>结果：<br><img src="/images/2009_2010%E5%AF%B9%E6%AF%94%E5%9B%BE.png" alt="2009_2010对比图"></p>
<p>其中，需要调用一个设置边界的函数:</p>
<figure class="highlight python"><table><tr><td class="code"><pre><span class="line">function ha = tight_subplot(Nh, Nw, gap, marg_h, marg_w)</span><br><span class="line"></span><br><span class="line"><span class="keyword">if</span> nargin&lt;<span class="number">3</span>; gap = <span class="number">.02</span>; end</span><br><span class="line"><span class="keyword">if</span> nargin&lt;<span class="number">4</span> || isempty(marg_h); marg_h = <span class="number">.05</span>; end</span><br><span class="line"><span class="keyword">if</span> nargin&lt;<span class="number">5</span>; marg_w = <span class="number">.05</span>; end</span><br><span class="line"></span><br><span class="line"><span class="keyword">if</span> numel(gap)==<span class="number">1</span>;</span><br><span class="line">    gap = [gap gap];</span><br><span class="line">end</span><br><span class="line"><span class="keyword">if</span> numel(marg_w)==<span class="number">1</span>;</span><br><span class="line">    marg_w = [marg_w marg_w];</span><br><span class="line">end</span><br><span class="line"><span class="keyword">if</span> numel(marg_h)==<span class="number">1</span>;</span><br><span class="line">    marg_h = [marg_h marg_h];</span><br><span class="line">end</span><br><span class="line"></span><br><span class="line">axh = (<span class="number">1</span>-<span class="built_in">sum</span>(marg_h)-(Nh-<span class="number">1</span>)*gap(<span class="number">1</span>))/Nh;</span><br><span class="line">axw = (<span class="number">1</span>-<span class="built_in">sum</span>(marg_w)-(Nw-<span class="number">1</span>)*gap(<span class="number">2</span>))/Nw;</span><br><span class="line"></span><br><span class="line">py = <span class="number">1</span>-marg_h(<span class="number">2</span>)-axh;</span><br><span class="line"></span><br><span class="line">ha = zeros(Nh*Nw,<span class="number">1</span>);</span><br><span class="line">ii = <span class="number">0</span>;</span><br><span class="line"><span class="keyword">for</span> ih = <span class="number">1</span>:Nh</span><br><span class="line">    px = marg_w(<span class="number">1</span>);</span><br><span class="line"></span><br><span class="line">    <span class="keyword">for</span> ix = <span class="number">1</span>:Nw</span><br><span class="line">        ii = ii+<span class="number">1</span>;</span><br><span class="line">        ha(ii) = axes(<span class="string">&#x27;Units&#x27;</span>,<span class="string">&#x27;normalized&#x27;</span>, ...</span><br><span class="line">            <span class="string">&#x27;Position&#x27;</span>,[px py axw axh], ...</span><br><span class="line">            <span class="string">&#x27;XTickLabel&#x27;</span>,<span class="string">&#x27;&#x27;</span>, ...</span><br><span class="line">            <span class="string">&#x27;YTickLabel&#x27;</span>,<span class="string">&#x27;&#x27;</span>);</span><br><span class="line">        px = px+axw+gap(<span class="number">2</span>);</span><br><span class="line">    end</span><br><span class="line">    py = py-axh-gap(<span class="number">1</span>);</span><br><span class="line">end</span><br></pre></td></tr></table></figure>
]]></content>
      <tags>
        <tag>科研技巧</tag>
      </tags>
